<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===== BACK BUTTON ROW ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:background="#FFFFFF"/>

        <!-- ===== HERO IMAGE WITH TITLE OVERLAY ===== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp">

            <!-- Hero Image -->
            <ImageView
                android:id="@+id/imgHero"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_background"/>

            <!-- Dark gradient overlay so text is readable -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#88000000"/>

            <!-- Category badge + Title at bottom of image -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="bottom"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvHeroCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LWIC — Society Event"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="#7B2FBE"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvHeroTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Girls Coding Camp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="26sp"/>

            </LinearLayout>

        </FrameLayout>

        <!-- ===== EVENT DETAILS CARD ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event Details"
                android:textColor="#1A1A2E"
                android:textStyle="bold"
                android:textSize="17sp"
                android:layout_marginBottom="16dp"/>

            <!-- Date Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="📅"
                    android:textSize="16sp"
                    android:textColor="#E53935"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="March 28, 2026"
                        android:textColor="#1A1A2E"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                </LinearLayout>
            </LinearLayout>

            <!-- Time Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="🕐"
                    android:textSize="16sp"
                    android:textColor="#E53935"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Time"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/tvTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="9:00 AM – 5:00 PM"
                        android:textColor="#1A1A2E"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                </LinearLayout>
            </LinearLayout>

            <!-- Venue Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="📍"
                    android:textSize="16sp"
                    android:textColor="#E53935"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Venue"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/tvVenue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CS Labs, SSE Building, LUMS"
                        android:textColor="#1A1A2E"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                </LinearLayout>
            </LinearLayout>

            <!-- Organizer Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="👥"
                    android:textSize="16sp"
                    android:textColor="#E53935"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Organizer"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/tvOrganizer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LWIC Society"
                        android:textColor="#1A1A2E"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                </LinearLayout>
            </LinearLayout>

            <!-- Registration Fee Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="wrap_content"
                    android:text="💰"
                    android:textSize="16sp"
                    android:textColor="#E53935"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Registration Fee"
                        android:textColor="#AAAAAA"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/tvFee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PKR 500"
                        android:textColor="#1A1A2E"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="14dp"/>

            <!-- Capacity -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Capacity"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvSeats"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="42 / 60 registered"
                    android:textColor="#1A1A2E"
                    android:textStyle="bold"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvSeatsPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="70% full"
                    android:textColor="#F5A623"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- Progress Bar -->
            <android.widget.ProgressBar
                android:id="@+id/progressSeats"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:max="100"
                android:progress="70"
                android:progressTint="#F5A623"
                android:progressBackgroundTint="#EEEEEE"/>

        </LinearLayout>

        <!-- ===== ABOUT THIS EVENT CARD ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="About this Event"
                android:textColor="#1A1A2E"
                android:textStyle="bold"
                android:textSize="17sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This is an exciting event that brings together students from across campus for a day of learning and networking. Join us for hands-on sessions and connect with industry professionals."
                android:textColor="#444444"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp"/>

        </LinearLayout>

        <!-- ===== EVENT SCHEDULE CARD ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event Schedule"
                android:textColor="#1A1A2E"
                android:textStyle="bold"
                android:textSize="17sp"
                android:layout_marginBottom="16dp"/>

            <!-- Schedule Item 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="09:00 AM"
                    android:textColor="#E53935"
                    android:textStyle="bold"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Opening Ceremony"
                        android:textColor="#1A1A2E"
                        android:textStyle="bold"
                        android:textSize="13sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome &amp; Introduction"
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#F0F0F0" android:layout_marginBottom="14dp"/>

            <!-- Schedule Item 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="10:00 AM"
                    android:textColor="#E53935"
                    android:textStyle="bold"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Workshop Session 1"
                        android:textColor="#1A1A2E"
                        android:textStyle="bold"
                        android:textSize="13sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Introduction to programming"
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#F0F0F0" android:layout_marginBottom="14dp"/>

            <!-- Schedule Item 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="12:30 PM"
                    android:textColor="#E53935"
                    android:textStyle="bold"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lunch Break"
                        android:textColor="#1A1A2E"
                        android:textStyle="bold"
                        android:textSize="13sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Networking &amp; refreshments"
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#F0F0F0" android:layout_marginBottom="14dp"/>

            <!-- Schedule Item 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="01:30 PM"
                    android:textColor="#E53935"
                    android:textStyle="bold"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Workshop Session 2"
                        android:textColor="#1A1A2E"
                        android:textStyle="bold"
                        android:textSize="13sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HTML, CSS &amp; JavaScript fundamentals"
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#F0F0F0" android:layout_marginBottom="14dp"/>

            <!-- Schedule Item 5 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="04:30 PM"
                    android:textColor="#E53935"
                    android:textStyle="bold"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Closing &amp; Certificates"
                        android:textColor="#1A1A2E"
                        android:textStyle="bold"
                        android:textSize="13sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Final remarks &amp; certificate distribution"
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- ===== ACTION BUTTONS CARD ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="8dp"
            android:elevation="2dp">

            <!-- Register Now -->
            <Button
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Register Now"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#E53935"
                android:layout_marginBottom="10dp"/>

            <!-- Add to Calendar -->
            <Button
                android:id="@+id/btnAddToCalendar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="↓  Add to Calendar"
                android:textColor="#1A1A2E"
                android:textSize="14sp"
                android:backgroundTint="#FFFFFF"
                android:layout_marginBottom="10dp"/>

            <!-- Back to Browse -->
            <Button
                android:id="@+id/btnBackBottom"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="← Back"
                android:textColor="#1A1A2E"
                android:textSize="14sp"
                android:backgroundTint="#F5F5F5"/>

        </LinearLayout>

        <!-- Registration closes note -->
        <TextView
            android:id="@+id/tvRegCloses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registration closes March 25, 2026"
            android:textColor="#888888"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="16dp"/>

    </LinearLayout>
</ScrollView>