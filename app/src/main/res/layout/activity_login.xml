<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFF0F3">

    <!-- Gradient background layer -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Top pink blob background -->
        <View
            android:layout_width="400dp"
            android:layout_height="400dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="-80dp"
            android:background="@drawable/bg_blob_top" />

        <!-- Bottom teal blob -->
        <View
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_gravity="bottom|end"
            android:layout_marginBottom="-60dp"
            android:layout_marginEnd="-60dp"
            android:background="@drawable/bg_blob_bottom" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="60dp"
            android:paddingBottom="40dp">

            <!-- App icon circle -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_icon_circle">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="✦"
                    android:textSize="32sp"
                    android:textColor="#FFFFFF" />
            </FrameLayout>

            <!-- App name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="LUMS EventHub"
                android:textSize="13sp"
                android:letterSpacing="0.15"
                android:textColor="#C47A8A"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <!-- Welcome heading -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Welcome Back"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#2D1B2E"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Sign in to continue"
                android:textSize="14sp"
                android:textColor="#9B7B86"
                android:layout_marginBottom="36dp" />

            <!-- Card container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="24dp"
                android:elevation="8dp">

                <!-- Username label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User ID"
                    android:textSize="12sp"
                    android:textColor="#9B7B86"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp" />

                <!-- Username field -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/bg_input_field">


                    <EditText
                        android:id="@+id/etUsername"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="e.g. #AD_admin"
                        android:inputType="text"
                        android:textColor="#2D1B2E"
                        android:textSize="15sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="@null"
                        android:gravity="center_vertical" />
                </FrameLayout>

                <!-- Password label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textSize="12sp"
                    android:textColor="#9B7B86"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp" />

                <!-- Password field -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    android:background="@drawable/bg_input_field">


                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Enter your password"
                        android:inputType="textPassword"
                        android:textColor="#2D1B2E"
                        android:textSize="15sp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="@null"
                        android:gravity="center_vertical" />
                </FrameLayout>

                <!-- Login button -->
                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Sign In"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.08"
                    android:background="@drawable/bg_button_login"
                    android:stateListAnimator="@null" />

                <!-- Hint text -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:text="Your dashboard is determined by your assigned ID"
                    android:textSize="11sp"
                    android:textColor="#C4A8B0"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Role badges -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#AD = Admin"
                    android:textSize="11sp"
                    android:textColor="#C47A8A"
                    android:textStyle="bold"
                    android:background="@drawable/bg_badge"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#ORG = Organizer"
                    android:textSize="11sp"
                    android:textColor="#7A5C9B"
                    android:textStyle="bold"
                    android:background="@drawable/bg_badge_purple"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#AT = Attendee"
                    android:textSize="11sp"
                    android:textColor="#2E6DA4"
                    android:textStyle="bold"
                    android:background="@drawable/bg_badge_blue"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp" />

            </LinearLayout>

        </LinearLayout>
    </FrameLayout>
</ScrollView>