<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml
    Role: Main dashboard layout for Organizer navigation
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E3F2FD"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LUMS EventHub"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:gravity="center"
        android:paddingBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Organizer Dashboard"
        android:textSize="16sp"
        android:textColor="#666666"
        android:gravity="center"
        android:paddingBottom="32dp"/>

    <Button
        android:id="@+id/btnFormBuilder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Form Settings"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnCheckIn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Live Check-In"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnPayments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Payment Verification"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnRegistrants"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Registrant Dashboard"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF"/>
    <Button
        android:id="@+id/btnAttendeeForm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Attendee Registration"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF"
        android:layout_marginTop="12dp"/>

</LinearLayout>