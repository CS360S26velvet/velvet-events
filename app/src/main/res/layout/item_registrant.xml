<?xml version="1.0" encoding="utf-8"?>
<!--
    item_registrant.xml
    Role: Layout for a single registrant row in the dashboard (US-28, US-29)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#FFFFFF"
    android:padding="12dp"
    android:layout_marginBottom="4dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvRegistrantName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hassan Raza"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#000000"/>

        <TextView
            android:id="@+id/tvRegistrantId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AT0041"
            android:textSize="12sp"
            android:textColor="#666666"/>

        <TextView
            android:id="@+id/tvRegistrantTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Started: 2 hours ago"
            android:textSize="11sp"
            android:textColor="#999999"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Incomplete"
        android:textSize="11sp"
        android:textColor="#FFFFFF"
        android:background="#F44336"
        android:padding="6dp"/>

</LinearLayout>