<?xml version="1.0" encoding="utf-8"?>
<!--
    item_option_row.xml
    Role: A single option row inside Multiple Choice / Checkboxes / Dropdown questions
    in the Form Builder. Contains an EditText for option text and a Remove button.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginBottom="4dp">

    <EditText
        android:id="@+id/etOptionText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:hint="Option text..."
        android:textSize="13sp"
        android:textColor="#000000"
        android:background="#F5F5F5"
        android:padding="8dp"
        android:inputType="textCapSentences"/>

    <Button
        android:id="@+id/btnRemoveOption"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:text="×"
        android:backgroundTint="#F44336"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:padding="0dp"
        android:layout_marginStart="6dp"/>

</LinearLayout>