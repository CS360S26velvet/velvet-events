<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0F3"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── HEADER BANNER ── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dashboard_header"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="28dp">

            <!-- Pink blob decoration -->
            <View
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="end|top"
                android:layout_marginTop="-40dp"
                android:layout_marginEnd="-40dp"
                android:background="@drawable/bg_blob_top"
                android:alpha="0.3" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Top row: title + sign out -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LUMS EventHub"
                            android:textSize="11sp"
                            android:textColor="#F9A8B8"
                            android:letterSpacing="0.12"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Admin Dashboard"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Manage events, approvals &amp; oversight"
                            android:textSize="12sp"
                            android:textColor="#F9C0CC" />
                    </LinearLayout>

                    <!-- Sign out button -->
                    <TextView
                        android:id="@+id/btnSignOut"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign Out"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:background="@drawable/bg_signout_btn"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp" />
                </LinearLayout>

                <!-- Username pill -->
                <TextView
                    android:id="@+id/tvUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CCA Admin"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/bg_username_pill"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- ── STATS CARDS ROW ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="4dp"
            android:weightSum="2">

            <!-- Pending Proposals card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_card"
                android:padding="16dp"
                android:layout_marginEnd="8dp"
                android:elevation="4dp">

                <TextView
                    android:id="@+id/tvPendingNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#E8637A" />

                <View
                    android:layout_width="32dp"
                    android:layout_height="3dp"
                    android:background="#E8637A"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pending\nProposals"
                    android:textSize="12sp"
                    android:textColor="#9B7B86" />
            </LinearLayout>

            <!-- Approved This Month card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_card"
                android:padding="16dp"
                android:layout_marginStart="8dp"
                android:elevation="4dp">

                <TextView
                    android:id="@+id/tvApprovedNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#27AE60" />

                <View
                    android:layout_width="32dp"
                    android:layout_height="3dp"
                    android:background="#27AE60"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Approved\nThis Month"
                    android:textSize="12sp"
                    android:textColor="#9B7B86" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:weightSum="2">

            <!-- Accommodation Requests card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_card"
                android:padding="16dp"
                android:layout_marginEnd="8dp"
                android:elevation="4dp">

                <TextView
                    android:id="@+id/tvAccomNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#F39C12" />

                <View
                    android:layout_width="32dp"
                    android:layout_height="3dp"
                    android:background="#F39C12"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accommodation\nRequests"
                    android:textSize="12sp"
                    android:textColor="#9B7B86" />
            </LinearLayout>

            <!-- Active Events card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_card"
                android:padding="16dp"
                android:layout_marginStart="8dp"
                android:elevation="4dp">

                <TextView
                    android:id="@+id/tvActiveNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#8E44AD" />

                <View
                    android:layout_width="32dp"
                    android:layout_height="3dp"
                    android:background="#8E44AD"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active\nEvents"
                    android:textSize="12sp"
                    android:textColor="#9B7B86" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── PENDING PROPOSALS SECTION ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="16dp"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:elevation="4dp"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp">

            <!-- Section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="20dp"
                    android:background="@drawable/bg_button_login"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pending Event Proposals"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2D1B2E" />

                <TextView
                    android:id="@+id/tvViewAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View All →"
                    android:textSize="12sp"
                    android:textColor="#E8637A"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Table header row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#FFF5F7"
                android:padding="10dp"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:text="SOCIETY"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#C47A8A"
                    android:letterSpacing="0.08" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.8"
                    android:text="EVENT NAME"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#C47A8A"
                    android:letterSpacing="0.08" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:text="DATE"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#C47A8A"
                    android:letterSpacing="0.08" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ACTION"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#C47A8A"
                    android:letterSpacing="0.08"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Dynamic proposals list container -->
            <LinearLayout
                android:id="@+id/llPendingProposals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Empty state -->
            <TextView
                android:id="@+id/tvNoPending"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No pending proposals"
                android:textSize="13sp"
                android:textColor="#C4A8B0"
                android:gravity="center"
                android:padding="20dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ── QUICK NAVIGATION ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Management Console"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#2D1B2E"
            android:layout_marginStart="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:weightSum="2"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/btnViewProposals"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_nav_card_pink"
                android:layout_marginEnd="8dp"
                android:elevation="3dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋"
                    android:textSize="22sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Proposals"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnAuditorium"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_nav_card_purple"
                android:layout_marginStart="8dp"
                android:elevation="3dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏛️"
                    android:textSize="22sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auditorium"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:weightSum="2"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:id="@+id/btnCalendar"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_nav_card_teal"
                android:layout_marginEnd="8dp"
                android:elevation="3dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅"
                    android:textSize="22sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calendar"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnAccommodation"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_nav_card_orange"
                android:layout_marginStart="8dp"
                android:elevation="3dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏨"
                    android:textSize="22sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accommodation"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>