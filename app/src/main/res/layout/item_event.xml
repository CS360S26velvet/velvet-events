<?xml version="1.0" encoding="utf-8"?>
<!--
    item_event.xml
    Role: Single event row in the OrganizerDashboard RecyclerView.
    White card, padding 12dp, marginBottom 8dp per colour system.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical">

    <!-- Left column: name + date -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvEventName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvEventDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#666666"
            android:textSize="13sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Status badge -->
    <TextView
        android:id="@+id/tvEventStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:padding="4dp"
        android:layout_marginStart="8dp" />

    <!-- Action button (Edit / Duplicate / hidden) -->
    <Button
        android:id="@+id/btnEventAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        android:layout_marginStart="8dp"
        android:visibility="gone" />

</LinearLayout>