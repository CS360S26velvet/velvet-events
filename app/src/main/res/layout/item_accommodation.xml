<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top row: event title + status badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAccomEvent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#2D1B2E" />

                <TextView
                    android:id="@+id/tvAccomSociety"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#C47A8A"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvAccomStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:background="@drawable/bg_badge" />
        </LinearLayout>

        <!-- Details grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GUEST / PARTICIPANT"
                    android:textSize="9sp"
                    android:textColor="#C47A8A"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvAccomGuest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#2D1B2E" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ROLE"
                    android:textSize="9sp"
                    android:textColor="#C47A8A"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvAccomRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#2D1B2E" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ROOMS"
                    android:textSize="9sp"
                    android:textColor="#C47A8A"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvAccomRooms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#2D1B2E" />
            </LinearLayout>
        </LinearLayout>

        <!-- Check-in / Check-out row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CHECK-IN"
                    android:textSize="9sp"
                    android:textColor="#C47A8A"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvAccomCheckIn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#2D1B2E" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CHECK-OUT"
                    android:textSize="9sp"
                    android:textColor="#C47A8A"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvAccomCheckOut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#2D1B2E" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F5D5DC"
            android:layout_marginBottom="12dp" />

        <!-- Action buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnAccomApprove"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="✓ Approve"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_btn_approve"
                android:stateListAnimator="@null"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnAccomReject"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="✕ Reject"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#E74C3C"
                android:background="@drawable/bg_btn_reject"
                android:stateListAnimator="@null" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>