<?xml version="1.0" encoding="utf-8"?>
<!--
    item_form_question.xml
    Role: Layout for a single question in the attendee registration form.
    Shows question label, required/optional badge, and input field.
    User Stories: AT US-06, US-07, US-09
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="16dp"
    android:layout_marginBottom="8dp">

    <!-- Question label + required badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tvQuestionLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Full Name"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#000000"/>

        <TextView
            android:id="@+id/tvRequiredBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Required"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:background="#F44336"
            android:padding="4dp"/>
    </LinearLayout>

    <!-- Input field (shown for Short Text, Paragraph) -->
    <EditText
        android:id="@+id/etAnswer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter your answer..."
        android:background="#F5F5F5"
        android:padding="10dp"
        android:visibility="visible"/>

</LinearLayout>