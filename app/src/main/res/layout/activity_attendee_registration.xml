<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_attendee_registration.xml
    Role: Shows all events registered under the society.
    Per event: name + "Build Reg Form" button.
    If no events: shows "No events yet" message.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E3F2FD">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1565C0"
        android:padding="16dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Attendee Registration"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select an event to build its registration form"
            android:textColor="#BBDEFB"
            android:textSize="13sp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- No events message (hidden when events exist) -->
    <TextView
        android:id="@+id/tvNoEvents"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No events yet. Create an event from the Organizer Dashboard first."
        android:textSize="15sp"
        android:textColor="#666666"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"/>

    <!-- Event list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewEvents"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"/>

</LinearLayout>