<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF0F3">

    <!-- HEADER -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dashboard_header"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="44dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Back"
                android:textColor="#F9C0CC"
                android:textSize="13sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accommodation Requests"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Review and forward to Residence Office"
                android:textSize="12sp"
                android:textColor="#F9C0CC" />
        </LinearLayout>
    </FrameLayout>

    <!-- STATS ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:weightSum="3">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_stat_card"
            android:padding="12dp"
            android:layout_marginEnd="6dp"
            android:elevation="3dp">
            <TextView
                android:id="@+id/tvStatPending"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#F39C12" />
            <View
                android:layout_width="28dp"
                android:layout_height="3dp"
                android:background="#F39C12"
                android:layout_marginTop="3dp"
                android:layout_marginBottom="5dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending"
                android:textSize="11sp"
                android:textColor="#9B7B86" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_stat_card"
            android:padding="12dp"
            android:layout_marginEnd="6dp"
            android:elevation="3dp">
            <TextView
                android:id="@+id/tvStatApproved"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#27AE60" />
            <View
                android:layout_width="28dp"
                android:layout_height="3dp"
                android:background="#27AE60"
                android:layout_marginTop="3dp"
                android:layout_marginBottom="5dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Approved"
                android:textSize="11sp"
                android:textColor="#9B7B86" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_stat_card"
            android:padding="12dp"
            android:elevation="3dp">
            <TextView
                android:id="@+id/tvStatRejected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#E74C3C" />
            <View
                android:layout_width="28dp"
                android:layout_height="3dp"
                android:background="#E74C3C"
                android:layout_marginTop="3dp"
                android:layout_marginBottom="5dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rejected"
                android:textSize="11sp"
                android:textColor="#9B7B86" />
        </LinearLayout>
    </LinearLayout>

    <!-- SECTION HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp">

        <View
            android:layout_width="4dp"
            android:layout_height="20dp"
            android:background="@drawable/bg_button_login"
            android:layout_marginEnd="10dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Accommodation Requests"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#2D1B2E" />

        <!-- Forward to Residence button -->
        <TextView
            android:id="@+id/btnForward"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="⬆ Forward All"
            android:gravity="center"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_login"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />
    </LinearLayout>

    <!-- REQUESTS LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAccommodations"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:clipToPadding="false" />

    <!-- EMPTY STATE -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No accommodation requests"
        android:textSize="14sp"
        android:textColor="#C4A8B0"
        android:gravity="center"
        android:padding="40dp"
        android:visibility="gone" />

    <!-- DOWNLOAD CSV BUTTON -->
    <Button
        android:id="@+id/btnDownload"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="⬇  Download CSV for Residence Office"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_btn_approve"
        android:stateListAnimator="@null"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:layout_marginTop="8dp" />

</LinearLayout>